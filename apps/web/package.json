{
  "name": "@nebula/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "analyze": "ANALYZE=true tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "type-check": "tsc -b",
    "test": "vitest --run --passWithNoTests",
    "clean": "shx rm -rf dist"
  },
  "dependencies": {
    "@nebula/core": "0.0.0",
    "@nebula/effects": "0.0.0",
    "@nebula/ui": "0.0.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "leva": "^0.10.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.1.17",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/three": "^0.184.0",
    "rollup-plugin-visualizer": "^7.0.1"
  }
}
